APP_ENV=local
APP_NAME=AI Resume Platform
API_PREFIX=/api

POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_password
POSTGRES_DB=resume_db
DATABASE_URL=postgresql+psycopg2://resume_user:resume_password@postgres:5432/resume_db

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change_me_super_secret_key_for_local_only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

AI_PROVIDER=mock
AI_MODEL=mock-v1
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
AI_TIMEOUT_SECONDS=30

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123
ADMIN_FULL_NAME=Local Admin

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
